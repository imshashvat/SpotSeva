# Root gitignore for SpotSeva project

# Env / Secrets
**/.env
**/.env.*

# Flutter/Dart related
**/.dart_tool/
**/.flutter-plugins
**/.flutter-plugins-dependencies
**/.pub-cache/
**/.pub/
**/build/
**/doc/api/
**/ios/Flutter/.last_build_id
**/android/app/debug
**/android/app/profile
**/android/app/release
**/app.*.symbols
**/app.*.map.json
**/local.properties
**/flutter_export_environment.sh

# Gradle related
**/.gradle/

# Node/Firebase functions related
**/node_modules/
/functions/lib/
**/npm-debug.log*
**/yarn-debug.log*
**/yarn-error.log*

# Firebase related
.firebase/
*-debug.log
firestore-debug.log
ui-debug.log
firebase-debug.log

# IDEs and editors
.idea/
.vscode/
*.iml
*.ipr
*.iws
*.swp
*.swo
.DS_Store
